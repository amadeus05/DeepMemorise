# Default: auto normalize line endings on commit (LF in repo)
* text=auto eol=lf

# Explicit source / config as text
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.html text eol=lf
*.css text eol=lf
*.svg text eol=lf
.env.example text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Shell
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts keep CRLF when needed
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.7z binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
